PORT=3001

# Comma-separated list of origins allowed for CORS. Avoid "*" in production.
# Example: http://localhost:3000,http://example.com
CORS_ORIGIN=http://localhost:3000

CONTACT_RECIPIENT_EMAIL=your-email@example.com

# SMTP / Email configuration
# For Gmail, do NOT use your account password. Use either a 16-character
# Gmail App Password (when 2-Step Verification is enabled) in `EMAIL_PASS`,
# or configure OAuth2 via EMAIL_OAUTH_CLIENT_ID, EMAIL_OAUTH_CLIENT_SECRET,
# and EMAIL_OAUTH_REFRESH_TOKEN. Gmail limits are roughly ~500 emails/day.

# Option A: App Password (Gmail)
EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-character-app-password

# Option B: OAuth2 (recommended for production)
# EMAIL_OAUTH_CLIENT_ID=
# EMAIL_OAUTH_CLIENT_SECRET=
# EMAIL_OAUTH_REFRESH_TOKEN=
# Optional short-lived access token (not required if refresh token is present)
# EMAIL_OAUTH_ACCESS_TOKEN=

# If using a custom SMTP provider instead of Gmail, provide the SMTP settings below
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

EMAIL_FROM="Portfolio Contact <your-email@example.com>"
